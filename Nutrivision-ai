        "    result_text = f\"**Detected Food:** {top_food.title()} (Confidence: {confidence:.2%})\\n\\n\"\n",
        "    result_text += f\"**Nutrition Information (per {nutrition['serving']}):**\\n\"\n",
        "    result_text += f\"• Calories: {nutrition['calories']} kcal\\n\"\n",
        "    result_text += f\"• Protein: {nutrition['protein']}g\\n\"\n",
        "    result_text += f\"• Category: {nutrition['category'].title()}\\n\\n\"\n",
        "\n",
        "    # Add alternatives\n",
        "    if len(predictions) > 1:\n",
        "        result_text += \"**Other possibilities:**\\n\"\n",
        "        for food, conf in predictions[1:]:\n",
        "            result_text += f\"• {food.title()} ({conf:.2%})\\n\"\n",
        "\n",
        "    # Create nutrition data for plotting\n",
        "    nutrition_data = pd.DataFrame({\n",
        "        'Nutrient': ['Calories', 'Protein'],\n",
        "        'Amount': [nutrition['calories'], nutrition['protein']]\n",
        "    })\n",
        "\n",
        "    return result_text, nutrition_data\n",
        "\n",
        "# Create Gradio interface\n",
        "def create_interface():\n",
        "    with gr.Blocks(theme=gr.themes.Soft()) as demo:\n",
        "        gr.Markdown(\"\"\"\n",
        "        # 🍽️ NutriVision AI\n",
        "        ### Upload a photo of your food to get instant nutrition information\n",
        "\n",
        "        Simply take a picture of your meal and I'll tell you the estimated calories and protein content!\n",
        "        \"\"\")\n",
        "\n",
        "        with gr.Row():\n",
        "            with gr.Column():\n",
        "                # Input\n",
        "                image_input = gr.Image(type=\"pil\", label=\"Upload Food Image\")\n",
        "                analyze_btn = gr.Button(\"🔍 Analyze Food\", variant=\"primary\")\n",
        "\n",
        "            with gr.Column():\n",
        "                # Output\n",
        "                result_output = gr.Markdown(label=\"Analysis Results\")\n",
        "                chart_output = gr.BarPlot(\n",
        "                    x=\"Nutrient\",\n",
        "                    y=\"Amount\",\n",
        "                    title=\"Nutrition Breakdown\",\n",
        "                    vertical=False,\n",
        "                    height=300\n",
        "                )\n",
        "\n",
        "        # Examples\n",
        "        gr.Markdown(\"### 📸 Try these examples:\")\n",
        "        gr.Examples(\n",
        "            examples=[\n",
        "                [\"example_fruit.jpg\"],\n",
        "                [\"example_pizza.jpg\"],\n",
        "                [\"example_salad.jpg\"],\n",
        "            ],\n",
        "            inputs=image_input,\n",
        "            outputs=[result_output, chart_output],\n",
        "            fn=analyze_food,\n",
        "            cache_examples=True\n",
        "        )\n",
        "\n",
        "        # Handle analysis\n",
        "        analyze_btn.click(\n",
        "            fn=analyze_food,\n",
        "            inputs=image_input,\n",
        "            outputs=[result_output, chart_output]\n",
        "        )\n",
        "\n",
        "        # Footer\n",
        "        gr.Markdown(\"\"\"\n",
        "        ---\n",
        "        *Note: This is an AI-powered estimation. For precise nutritional information,\n",
        "        please consult food packaging or professional nutritionists.*\n",
        "        \"\"\")\n",
        "\n",
        "    return demo\n",
        "\n",
        "# Launch the app\n",
        "demo = create_interface()\n",
        "demo.launch(share=True)"
      ]
    }
